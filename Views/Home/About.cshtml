@{
    ViewData["Title"] = "About";
    ViewData["Page"] = "About";
}

<div class="hero-section" style="background: linear-gradient(105deg,#262f38,#1b2b2f);">
    <h1>Craftsmanship with integrity</h1>
    <p class="hero-sub">From foundation to finishing – family-owned, passion-driven.</p>
</div>

<div class="section-wrap">
    <div class="grid-2">
        <div class="card" style="padding:2.5rem;">
            <i class="fas fa-drafting-compass icon-lg"></i>
            <h2 style="margin:1rem 0;">Our story</h2>
            <p>SbuNolda Construction started in 2019 with one mission: combine modern engineering
               with old‑world craftsmanship. Today we're a team of 10+ architects, engineers,
               and artisans creating spaces that last.</p>
            <p style="margin-top:1rem;">
                <i class="fa-solid fa-certificate" style="color:#b45f2b;"></i>
                Licensed &amp; bonded · EPA certified · ISO 9001
            </p>
        </div>
        <div class="card" style="background:#eedfd5;">
            <h3><i class="fa-regular fa-gem"></i> Our values</h3>
            <ul class="values-list">
                <li>🔨 <strong>Transparency</strong> — you see every cost upfront</li>
                <li>🤝 <strong>Collaboration</strong> — your ideas shape our work</li>
                <li>🏆 <strong>Excellence</strong> — no shortcuts, ever</li>
            </ul>
        </div>
    </div>

    <h2 class="section-title" style="margin-top:3rem;">Meet the core team</h2>
    <div class="grid-3">
        <div class="card team-member">
            <div class="team-img"><i class="fa-regular fa-user"></i></div>
            <h3>Onthatile Sekgwelea</h3>
            <p>CEO &amp; senior architect</p>
            <p class="team-tagline">5 years shaping skylines</p>
        </div>
        <div class="card team-member">
            <div class="team-img"><i class="fa-regular fa-user"></i></div>
            <h3>Bila</h3>
            <p>Head of construction</p>
            <p class="team-tagline">"Safety is not a slogan"</p>
        </div>
        <div class="card team-member">
            <div class="team-img"><i class="fa-regular fa-user"></i></div>
            <h3>Boitshepo Sekgwelea</h3>
            <p>Lead designer</p>
            <p class="team-tagline">Award‑winning interiors</p>
        </div>
    </div>
</div>
