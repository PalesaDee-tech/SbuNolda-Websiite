@{
    ViewData["Title"] = "Home";
    ViewData["Page"] = "Home";
}

<!-- HERO -->
<div class="hero-section">
    <h1>Build your vision.<br /><span class="hero-accent">We craft the future.</span></h1>
    <p class="hero-sub">Premium construction &amp; renovation – residential, commercial, industrial.</p>
    <a asp-controller="Home" asp-action="Contact" class="btn">
        Get a quote <i class="fa-regular fa-handshake"></i>
    </a>
</div>

<!-- STATS -->
<div class="home-stats">
    <div class="stat-item">
        <span class="stat-number" data-target="7">0</span>
        <br />years trust
    </div>
    <div class="stat-item">
        <span class="stat-number" data-target="320">0</span>
        <br />projects delivered
    </div>
    <div class="stat-item">
        <span class="stat-number" data-target="100">0</span>%
        <br />satisfaction
    </div>
    <div class="stat-item">
        <span class="stat-big">24/7</span>
        <br />support
    </div>
</div>

<!-- WHY US -->
<div class="section-wrap">
    <h2 class="section-title">Why choose SbuNolda</h2>
    <div class="grid-3">
        <div class="card">
            <i class="fas fa-hard-hat icon-lg"></i>
            <h3>Safety first</h3>
            <p>Zero-compromise safety standards, certified crew and modern equipment.</p>
        </div>
        <div class="card">
            <i class="fas fa-clock icon-lg"></i>
            <h3>On time, on budget</h3>
            <p>We respect deadlines and your investment – guaranteed cost control.</p>
        </div>
        <div class="card">
            <i class="fas fa-leaf icon-lg"></i>
            <h3>Sustainable builds</h3>
            <p>Eco-friendly materials &amp; energy-efficient planning for tomorrow.</p>
        </div>
    </div>
</div>
