@{
    ViewData["Title"] = "Services";
    ViewData["Page"] = "Services";
}

<div class="hero-section" style="background:#1b2a32;">
    <h1>Our expertise, your peace of mind</h1>
    <p class="hero-sub">Full‑service construction – from groundbreak to handover.</p>
</div>

<div class="section-wrap">
    <div class="service-feature">
        <i class="fas fa-home"></i>
        <div>
            <h3>Residential construction</h3>
            <p>Custom homes, extensions, luxury renovations. We build your dream with quality finishes.</p>
        </div>
    </div>
    <div class="service-feature">
        <i class="fas fa-warehouse"></i>
        <div>
            <h3>Commercial &amp; industrial</h3>
            <p>Office complexes, retail, warehouses – delivered on schedule, code compliant.</p>
        </div>
    </div>
    <div class="service-feature">
        <i class="fas fa-bridge-water"></i>
        <div>
            <h3>Infrastructure &amp; site prep</h3>
            <p>Excavation, utilities, roads. We prepare the ground for success.</p>
        </div>
    </div>
    <div class="service-feature">
        <i class="fas fa-paint-roller"></i>
        <div>
            <h3>Renovation &amp; remodelling</h3>
            <p>Breathing new life into existing structures – kitchens, basements, full makeovers.</p>
        </div>
    </div>

    <div class="card promo-card">
        <p><i class="fa-regular fa-message"></i> Every project includes a <strong>free consultation &amp; 3D mockup</strong>.</p>
        <a asp-controller="Home" asp-action="Contact" class="btn" style="margin-top:1.2rem;">
            Book your free consult
        </a>
    </div>
</div>
