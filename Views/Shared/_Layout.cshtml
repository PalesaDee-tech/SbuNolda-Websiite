<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SbuNolda Construction</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="logo">
        <i class="fas fa-helmet-safety"></i> SbuNolda<span class="logo-orange"> Construction</span>
    </a>
    <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
    <div class="nav-links" id="navLinks">
        <a asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewData["Page"]?.ToString() == "Home" ? "active" : "")">Home</a>
        <a asp-controller="Home" asp-action="About"
           class="nav-link @(ViewData["Page"]?.ToString() == "About" ? "active" : "")">About</a>
        <a asp-controller="Home" asp-action="Services"
           class="nav-link @(ViewData["Page"]?.ToString() == "Services" ? "active" : "")">Services</a>
        <a asp-controller="Home" asp-action="Contact"
           class="nav-link @(ViewData["Page"]?.ToString() == "Contact" ? "active" : "")">Contact</a>
    </div>
</nav>

<main>
    @RenderBody()
</main>

<footer class="footer">
    <p>🏗️ &copy; 2019 SbuNolda Construction — built with integrity, steel &amp; code</p>
    <div class="footer-icons">
        <i class="fa-brands fa-facebook"></i>
        <i class="fa-brands fa-instagram"></i>
        <i class="fa-brands fa-linkedin"></i>
        <i class="fa-brands fa-youtube"></i>
    </div>
</footer>

<script src="~/js/site.js"></script>
</body>
</html>
