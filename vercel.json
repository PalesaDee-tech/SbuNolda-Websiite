
    {
        "routes": [
            {
                "src": "/static/(.*)",
                "dest": "/static/$1"
            },
            {
                "src": "/assets/(.*)",
                "dest": "/assets/$1"
            },
            {
                "src": "/(.*\\.js)",
                "dest": "/$1"
            },
            {
                "src": "/(.*\\.css)",
                "dest": "/$1"
            },
            {
                "src": "/(.*\\.ico)",
                "dest": "/$1"
            },
            {
                "src": "/(.*\\.png)",
                "dest": "/$1"
            },
            {
                "src": "/editor/(?<roomId>[^/]+)",
                "dest": "/SbuNolda.html"
            },
            {
                "src": "/login",
                "dest": "/SbuNolda.html"
            },
            {
                "src": "/register",
                "dest": "/SbuNolda.html"
            },
            {
                "src": "/createRoom",
                "dest": "/SbuNolda.html"
            },
            {
                "src": "/",
                "dest": "/SbuNolda.html"
            },
            {
                "src": "/.*",
                "dest": "/SbuNolda.html"
            }
        ]
    }
